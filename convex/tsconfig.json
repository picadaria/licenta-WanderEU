{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "convex/_generated/api": ["./_generated/api"],
      "convex/_generated/api.d.ts": ["./_generated/api.d.ts"],
      "convex/_generated/dataModel": ["./_generated/dataModel"],
      "convex/_generated/dataModel.d.ts": ["./_generated/dataModel.d.ts"],
      "convex/_generated/server": ["./_generated/server"],
      "convex/_generated/server.d.ts": ["./_generated/server.d.ts"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "_generated"]
}
